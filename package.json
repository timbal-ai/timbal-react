{
  "name": "@timbal-ai/timbal-react",
  "version": "3.1.0",
  "description": "React components and runtime for building Timbal chat and studio apps",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "bin": {
    "timbal-ui-lint": "dist/cli/timbal-ui-lint.mjs"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.esm.js",
      "require": "./dist/index.cjs"
    },
    "./chat": {
      "types": "./dist/chat.d.ts",
      "import": "./dist/chat.esm.js",
      "require": "./dist/chat.cjs"
    },
    "./studio": {
      "types": "./dist/studio.d.ts",
      "import": "./dist/studio.esm.js",
      "require": "./dist/studio.cjs"
    },
    "./ui": {
      "types": "./dist/ui.d.ts",
      "import": "./dist/ui.esm.js",
      "require": "./dist/ui.cjs"
    },
    "./app": {
      "types": "./dist/app.d.ts",
      "import": "./dist/app.esm.js",
      "require": "./dist/app.cjs"
    },
    "./site": {
      "types": "./dist/site.d.ts",
      "import": "./dist/site.esm.js",
      "require": "./dist/site.cjs"
    },
    "./styles.css": "./dist/styles.css",
    "./vite": {
      "types": "./vite/local-dev.d.ts",
      "import": "./vite/local-dev.mjs"
    }
  },
  "files": [
    "dist",
    "vite",
    "scripts/dev-linked.mjs",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup && tsup --config tsup.cli.config.ts",
    "build:watch": "tsup --watch",
    "clean": "rm -rf dist",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "typecheck": "tsc --noEmit",
    "check:boundaries": "depcruise src --config .dependency-cruiser.cjs",
    "check:bundle": "bun run build && node scripts/check-bundle-sizes.mjs",
    "check:deps": "node scripts/check-immer.mjs",
    "example:install": "npm install --prefix examples/mock-ui && npm install --prefix examples/app-kit",
    "example:mock": "node scripts/dev-linked.mjs examples/mock-ui vite",
    "example:app": "node scripts/dev-linked.mjs examples/app-kit vite",
    "prepublishOnly": "bun run build && bun run typecheck"
  },
  "peerDependencies": {
    "@assistant-ui/react": ">=0.12",
    "@timbal-ai/timbal-sdk": ">=0.4",
    "react": ">=19",
    "react-dom": ">=19",
    "react-is": ">=19"
  },
  "dependencies": {
    "@assistant-ui/react-markdown": "^0.12.3",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@paper-design/shaders-react": "^0.0.76",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.2.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "katex": "^0.16.28",
    "liquid-glass-react": "^1.1.1",
    "lucide-react": "^0.574.0",
    "motion": "^12.23.24",
    "radix-ui": "^1.4.3",
    "react-day-picker": "^10.0.1",
    "recharts": "3.8.1",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "shiki": "^3.15.0",
    "tailwind-merge": "^3.4.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@assistant-ui/react": "^0.12.10",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@timbal-ai/timbal-sdk": "0.4.9",
    "@types/react": "^19.2.4",
    "@types/react-dom": "^19.2.3",
    "@types/react-is": "^19.2.0",
    "dependency-cruiser": "^16.10.4",
    "happy-dom": "^20.8.9",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-is": "^19.2.0",
    "tsup": "^8.5.0",
    "typescript": "~5.8.3"
  },
  "overrides": {
    "immer": ">=11.0.1"
  },
  "resolutions": {
    "immer": ">=11.0.1"
  },
  "keywords": [
    "timbal",
    "react",
    "chat",
    "ai",
    "components",
    "ui",
    "streaming",
    "assistant"
  ],
  "author": "",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/timbal-ai/timbal-react.git"
  },
  "bugs": {
    "url": "https://github.com/timbal-ai/timbal-react/issues"
  },
  "homepage": "https://github.com/timbal-ai/timbal-react#readme",
  "patchedDependencies": {
    "@assistant-ui/react@0.12.21": "patches/@assistant-ui%2Freact@0.12.21.patch"
  }
}
